# SDK — https://supabase.com/dashboard/project/SEU_REF/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://gvxtzvcxjodpyvaxiqqn.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sua-chave-publishable"

# Prisma — Connect → ORMs → Prisma
# Local (recomendado): Direct connection, porta 5432, usuário postgres
DATABASE_URL="postgresql://postgres:SUA_SENHA@db.gvxtzvcxjodpyvaxiqqn.supabase.co:5432/postgres"
DIRECT_DATABASE_URL="postgresql://postgres:SUA_SENHA@db.gvxtzvcxjodpyvaxiqqn.supabase.co:5432/postgres"

# Senha em texto puro (evita erro ao codificar @ na URL). Opcional se a senha já está na URL.
# SUPABASE_DB_PASSWORD="SUA_SENHA"

# Vercel: session pooler 5432 (recomendado) ou Direct + IPv4 no Supabase
# DATABASE_URL="postgresql://postgres.gvxtzvcxjodpyvaxiqqn:SUA_SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# Configuração automática: Copy-Item .env.supabase.example .env.supabase && npm run supabase:configure

# NextAuth
AUTH_SECRET="gere-com-openssl-ou-powershell-ver-SUPABASE.md"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"
