generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  SELLER
  EMPLOYEE
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum QuoteStatus {
  PENDING
  APPROVED
  CANCELLED
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  PIX
  BANK_TRANSFER
  OTHER
}

enum PixKeyType {
  CPF
  CNPJ
  EMAIL
  PHONE
  RANDOM
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum ServiceOrderStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum GlassColor {
  INCOLOR
  VERDE
  FUME
  REFLETIVO
}

enum GlassThickness {
  MM_6
  MM_8
  MM_10
}

model User {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  password       String
  role           UserRole        @default(SELLER)
  image          String?
  active         Boolean         @default(true)
  lastSeenAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  sales          Sale[]
  quotes         Quote[]
  stockMovements StockMovement[]
  serviceOrders          ServiceOrder[] @relation("ServiceOrderCreator")
  serviceOrdersStarted   ServiceOrder[] @relation("ServiceOrderStartedBy")
  serviceOrdersCompleted ServiceOrder[] @relation("ServiceOrderCompletedBy")
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id             String          @id @default(cuid())
  name           String
  sku            String          @unique
  categoryId     String
  category       Category        @relation(fields: [categoryId], references: [id])
  description     String?
  glassColor      GlassColor?
  glassThickness  GlassThickness?
  heightMm        Int?
  widthMm         Int?
  salePrice      Decimal         @db.Decimal(10, 2)
  stock          Int             @default(0)
  image          String?
  barcode        String?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  saleItems      SaleItem[]
  quoteItems     QuoteItem[]
  stockMovements StockMovement[]

  @@index([categoryId])
  @@index([name])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  document  String   @unique
  phone     String?
  email     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sales     Sale[]
  quotes    Quote[]
  serviceOrders ServiceOrder[]

  @@index([name])
}

model Sale {
  id            String        @id @default(cuid())
  code          String        @unique
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  quoteId       String?
  subtotal      Decimal       @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  downPayment   Decimal       @default(0) @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  status        SaleStatus    @default(PENDING)
  paymentMethod PaymentMethod @default(PIX)
  installments  Int           @default(1)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         SaleItem[]
  serviceOrder  ServiceOrder?

  @@index([customerId])
  @@index([quoteId])
  @@index([createdAt])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)
}

model Quote {
  id         String      @id @default(cuid())
  code       String      @unique
  customerId String
  customer   Customer    @relation(fields: [customerId], references: [id])
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  subtotal   Decimal     @db.Decimal(10, 2)
  discount   Decimal     @default(0) @db.Decimal(10, 2)
  total      Decimal     @db.Decimal(10, 2)
  status     QuoteStatus @default(PENDING)
  validUntil DateTime?
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  items      QuoteItem[]

  @@index([customerId])
  @@index([status])
}

model QuoteItem {
  id        String  @id @default(cuid())
  quoteId   String
  quote     Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)
}

model StockMovement {
  id        String            @id @default(cuid())
  productId String
  product   Product           @relation(fields: [productId], references: [id])
  userId    String
  user      User              @relation(fields: [userId], references: [id])
  type      StockMovementType
  quantity  Int
  reason    String?
  createdAt DateTime          @default(now())

  @@index([productId])
  @@index([createdAt])
}

model ServiceOrder {
  id          String             @id @default(cuid())
  code        String             @unique
  saleId      String             @unique
  sale        Sale               @relation(fields: [saleId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer           @relation(fields: [customerId], references: [id])
  userId        String
  user          User               @relation("ServiceOrderCreator", fields: [userId], references: [id])
  startedById   String?
  startedBy     User?              @relation("ServiceOrderStartedBy", fields: [startedById], references: [id])
  completedById String?
  completedBy   User?              @relation("ServiceOrderCompletedBy", fields: [completedById], references: [id])
  status        ServiceOrderStatus @default(OPEN)
  description   String?
  scheduledAt   DateTime?
  completedAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model CompanySettings {
  id            String   @id @default(cuid())
  name          String   @default("Minha Empresa")
  document      String?
  email         String?
  phone         String?
  address       String?
  logo          String?
  currency      String   @default("BRL")
  taxRate       Decimal  @default(0) @db.Decimal(5, 2)
  lowStockAlert Int      @default(5)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PixKey {
  id        String     @id @default(cuid())
  label     String
  key       String
  keyType   PixKeyType @default(RANDOM)
  isDefault Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([isDefault])
}

model FinancialTransaction {
  id          String          @id @default(cuid())
  description String
  amount      Decimal         @db.Decimal(10, 2)
  type        TransactionType
  category    String?
  saleId      String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())

  @@index([date])
  @@index([type])
}
